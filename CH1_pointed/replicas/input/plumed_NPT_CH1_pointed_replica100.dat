UNITS LENGTH=A TIME=fs ENERGY=kcal/mol

#DUMPMASSCHARGE FILE=mcfile

# --- DEFINE GROUPS ---
A1: GROUP NDX_FILE=CH1_pointed_plumed.ndx NDX_GROUP=A1_&_C-alpha
A2: GROUP NDX_FILE=CH1_pointed_plumed.ndx NDX_GROUP=A2_&_C-alpha
A3: GROUP NDX_FILE=CH1_pointed_plumed.ndx NDX_GROUP=A3_&_C-alpha

CH1: GROUP NDX_FILE=CH1_pointed_plumed.ndx NDX_GROUP=CH1_&_C-alpha
CH1_AllAtom: GROUP NDX_FILE=CH1_pointed_plumed.ndx NDX_GROUP=CH1
CH2: GROUP NDX_FILE=CH1_pointed_plumed.ndx NDX_GROUP=CH2_&_C-alpha
CH2_AllAtom: GROUP NDX_FILE=CH1_pointed_plumed.ndx NDX_GROUP=CH2

All_Actin: GROUP ATOMS=A1,A2,A3
A1_A3: GROUP ATOMS=A1,A3
CH1_2: GROUP ATOMS=CH1_AllAtom,CH2_AllAtom

# --- SET ANCHORS ---
A1_COM: COM ATOMS=A1
A2_COM: COM ATOMS=A2
A3_COM: COM ATOMS=A3
anc1: COM ATOMS=A1,A2 NOPBC
anc2: COM ATOMS=A2,A3 NOPBC
All_Actin_COM: COM ATOMS=All_Actin
a-actn: COM ATOMS=CH1,CH2 NOPBC
CH1_COM: COM ATOMS=CH1 NOPBC
CH2_COM: COM ATOMS=CH2 NOPBC

pocket: COM ATOMS=A1,A3

# --- MEASURE DISTANCES ---
CH_Actin: DISTANCE ATOMS=a-actn,All_Actin_COM

CH1_A1: DISTANCE ATOMS=CH1_COM,A1_COM
CH2_A1: DISTANCE ATOMS=CH2_COM,A1_COM
CH1_A3: DISTANCE ATOMS=CH1_COM,A3_COM
CH2_A3: DISTANCE ATOMS=CH2_COM,A3_COM

CH1_CH2_Dist: DISTANCE ATOMS=CH1_COM,CH2_COM

d1: DISTANCE ATOMS=pocket,a-actn COMPONENTS
real: DISTANCE ATOMS=pocket,a-actn

#CH_A12_Coordination: COORDINATIONNUMBER SPECIESA=CH1_2 SPECIESB=A1_A3 R_0=10.0 MORE_THAN={RATIONAL R_0=6.0 NN=6 MM=12 D_0=0}

# --- DIHEDRAL ---
#dihedral: TORSION ATOMS=CH1_COM,A1_COM,A3_COM,CH2_COM

PRINT ARG=* STRIDE=1 FILE=CH1_pointed_1microsec_NPT_COLVAR_replica_100
ENDPLUMED
